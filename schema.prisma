generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lot {
  id          String   @id @default(cuid())
  source      String
  sourceUrl   String
  title       String?
  address     String?
  postcode    String?
  bedrooms    Int?
  guidePrice  String?
  status      String   @default("unsold")
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt

  dedupeKey   String   @unique
}
